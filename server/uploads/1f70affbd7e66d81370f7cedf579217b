<script>
  function manageVideoClicks(el,video){
    let allVideos = document.querySelectorAll('.card-widget-container .custom-video-tag video');
    let paused = video.paused;
    allVideos.forEach(vid => {vid.pause();vid.muted = true;vid.closest('.custom-video-tag').classList.remove('active')});
    if(paused){
       video.play();
       video.muted = false;
      el.classList.add('active');
    }else{
      video.pause();
      video.muted = true;
      el.classList.remove('active');
    }
  }
  function offToScroll(element){
       const rect = element.getBoundingClientRect();
    return (
        rect.top >= 0 &&
        rect.left >= 0 &&
        rect.bottom <= (window.innerHeight || document.documentElement.clientHeight) &&
        rect.right <= (window.innerWidth || document.documentElement.clientWidth)
    );
  }
 document.onscroll = ()=>{
   let activeVideo = document.querySelector('.widget-section-wrapper .custom-video-tag.active video');
     if(!activeVideo) return;
        let status = window.offToScroll(activeVideo);
       if(status){
           if(activeVideo && activeVideo.paused){
             activeVideo.play();
           }
       }
        else {
           activeVideo.pause();
        }
      }
