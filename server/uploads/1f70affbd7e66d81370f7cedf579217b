                                <script>
          class CustomSelect extends HTMLElement {
            constructor(){
             super();
              this.elements = {
                containerElement : this.querySelector('.custom-select-container'),
                selectedValue : this.querySelector('.custom-selected-value'),
                buttonSelector : this.querySelector('.custom-selected-value-container button'),
                bodyContainer : this.querySelector('.custom-select-body'),
                allInputs : this.querySelectorAll('input[data-lineitem]')
              }
             this.init();
            }
            
            init(){
                          /* Selector Button Event*/
               this.elements.buttonSelector.addEventListener('click', ()=>{
                 this.elements.containerElement.classList.toggle('active');
               });
              
                        /* item Change Event */
              this.elements.allInputs.forEach(item =>{
                item.addEventListener('change', this.itemChanged.bind(this));
              });
              this.setMaxHeight();
            }
            
            itemChanged(){
              console.log(this);
              this.elements.containerElement.classList.toggle('active');
              this.updateSelectedValue();
            }
            updateSelectedValue(){
              let selectedValue = this.querySelector('input[data-lineitem]:checked').value;
              this.elements.selectedValue.innerHTML = selectedValue;
            }
            
            setMaxHeight(){
             let totalHeight = this.elements.bodyContainer.scrollHeight;
              this.elements.bodyContainer.style.maxHeight = totalHeight + 20 +'px';
            }
          }
          customElements.define('custom-select', CustomSelect)
        </script>
                              
